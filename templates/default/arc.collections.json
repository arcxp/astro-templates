    {
      "_id": "STORY00FIRSTPOST0000000000000",
      "canonical_url": "/blog/your-first-blog-post",
      "content_elements": [
        {
          "_id": "el-b1",
          "content": "This is your first blog post, served from the <code>blog</code> collection in <code>arc.collections.json</code>. It renders through the very same <code>[...slug].astro</code> page as the front stories.",
          "type": "text"
        },
        {
          "_id": "el-b2",
          "content": "Editing this post",
          "level": 2,
          "type": "header"
        },
        {
          "_id": "el-b3",
          "content": "Change the <code>headlines.basic</code> or <code>content_elements</code> here, save, and the dev server hot-reloads with your new copy.",
          "type": "text"
        },
        {
          "_id": "el-b4",
          "content": "Notice the story link on the blog listing was built with <code>withBase()</code> — so it keeps working even after you set a base <code>path</code> in <code>arc.config.ts</code>.",
          "type": "text"
        }
      ],
