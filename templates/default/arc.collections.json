    {
      "_id": "STORY00DEPLOY000000000000000",
      "canonical_url": "/deploy",
      "content_elements": [
        {
          "_id": "el-d1",
          "content": "<code>pnpm build</code> produces a Worker bundle and <code>wrangler.jsonc</code>. Both are managed by the integration — you should not need to hand-edit them.",
          "type": "text"
        },
        {
          "_id": "el-d2",
          "content": "First deploy",
          "level": 2,
          "type": "header"
        },
        {
          "_id": "el-d3",
          "content": "Run <code>npx wrangler deploy</code>. Cloudflare assigns your Worker a default <code>workers.dev</code> subdomain. Map a custom domain through the Cloudflare dashboard when you're ready.",
          "type": "text"
        },
        {
          "_id": "el-d4",
          "content": "Production secrets",
          "level": 2,
          "type": "header"
        },
        {
          "_id": "el-d5",
          "content": "Inject <code>ARC_API_TOKEN</code> with <code>npx wrangler secret put ARC_API_TOKEN</code>. The token is scoped to your org + site + env in the Arc dashboard.",
          "type": "text"
        }
      ],
      "credits": {
        "by": [
          {
            "_id": "jordan-devrel",
            "additional_properties": { "original": { "role": "Developer Advocate" } },
            "image": { "url": "https://i.pravatar.cc/150?u=jordan-devrel" },
            "name": "Jordan DevRel"
          }
        ]
      },
      "description": {
        "basic": "Cloudflare Workers gives you a global edge runtime out of the box. The @arc/astro integration generates the wrangler.jsonc so you can focus on routes and content."
      },
      "display_date": "2026-06-08T10:00:00Z",
      "headlines": { "basic": "From template to production: deploying to Cloudflare" },
      "last_updated_date": "2026-06-08T10:00:00Z",
