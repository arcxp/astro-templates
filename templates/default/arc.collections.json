    {
      "_id": "STORY00LIVECONTENT00000000000",
      "canonical_url": "/live-content",
      "content_elements": [
        {
          "_id": "el-l1",
          "content": "A <em>live collection</em> is a content collection whose entries are fetched on every request instead of baked into the build.",
          "type": "text"
        },
        {
          "_id": "el-l2",
          "content": "The contract",
          "level": 2,
          "type": "header"
        },
        {
          "_id": "el-l3",
          "content": "You define a loader once in <code>src/live.config.ts</code>. The loader fetches data from somewhere — a CMS API, a database, a file. Astro calls it on each request and passes the result to your page.",
          "type": "text"
        },
        {
          "_id": "el-l4",
          "content": "What <code>@arc/collections</code> adds",
          "level": 2,
          "type": "header"
        },
        {
          "_id": "el-l5",
          "content": "Two factories — <code>arcCollections({ alias })</code> for section fronts and <code>arcStory()</code> for individual stories. Both honor <code>ARC_USE_FIXTURES</code> so you can develop offline.",
          "type": "text"
        }
      ],
      "credits": {
        "by": [
          {
            "_id": "sam-platform",
            "additional_properties": { "original": { "role": "Platform Engineer" } },
            "image": { "url": "https://i.pravatar.cc/150?u=sam-platform" },
            "name": "Sam Platform"
          }
        ]
      },
      "description": {
        "basic": "Astro 6's live collections fetch content on each request. The @arc/collections loader wraps the Arc Content API so your pages stay fresh without rebuilds."
      },
      "display_date": "2026-06-09T15:30:00Z",
      "headlines": { "basic": "Live collections, explained in 60 seconds" },
      "last_updated_date": "2026-06-09T15:30:00Z",
      "planning": { "story_length": { "word_count_actual": 220 } },
      "promo_items": {
