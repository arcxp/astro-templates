  "stories": [
    {
      "_id": "STORY00WELCOME0000000000000",
      "canonical_url": "/welcome",
      "content_elements": [
        {
          "_id": "el-w1",
          "content": "You're looking at the starter template's <b>fixture-mode</b> output. Every field on this page comes from <code>arc.collections.json</code>.",
          "type": "text"
        },
        {
          "_id": "el-w2",
          "content": "What you can edit right now",
          "level": 2,
          "type": "header"
        },
        {
          "_id": "el-w3",
          "content": "Open <code>arc.collections.json</code> and change a headline. Save. The dev server hot-reloads and the new headline appears.",
          "type": "text"
        },
        {
          "_id": "el-w4",
          "content": "Switching to live content",
          "level": 2,
          "type": "header"
        },
        {
          "_id": "el-w5",
          "content": "Set <code>ARC_API_TOKEN</code> in <code>.env</code> and unset <code>ARC_USE_FIXTURES</code>. The same pages now render whatever your Arc Content API returns — no code changes.",
          "type": "text"
        }
      ],
      "credits": {
        "by": [
          {
            "_id": "alex-editor",
            "additional_properties": { "original": { "role": "Editor in Chief" } },
            "image": { "url": "https://i.pravatar.cc/150?u=alex-editor" },
            "name": "Alex Editor"
          }
        ]
      },
      "description": {
        "basic": "This is the starter template's `front` collection rendered from arc.collections.json. Replace the fixture or set ARC_API_TOKEN to fetch live stories."
      },
      "display_date": "2026-06-10T08:00:00Z",
      "headlines": { "basic": "Welcome to your Arc Astro site" },
      "last_updated_date": "2026-06-10T08:00:00Z",
      "planning": { "story_length": { "word_count_actual": 180 } },
      "promo_items": {
