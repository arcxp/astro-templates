    {
      "_id": "STORY00SECONDPOST000000000000",
      "canonical_url": "/blog/writing-with-content-elements",
      "content_elements": [
        {
          "_id": "el-c1",
          "content": "An Arc story body is an ordered list of <code>content_elements</code>. The template renders the common ones for you.",
          "type": "text"
        },
        {
          "_id": "el-c2",
          "content": "Element types",
          "level": 2,
          "type": "header"
        },
        {
          "_id": "el-c3",
          "content": "Paragraphs (<code>text</code>), headers, images, lists, blockquotes, and dividers are all supported out of the box:",
          "type": "text"
        },
        {
          "_id": "el-c4",
          "items": [
            { "_id": "el-c4a", "content": "<code>text</code> — a paragraph of rich text", "type": "text" },
            { "_id": "el-c4b", "content": "<code>header</code> — a section heading", "type": "text" },
            { "_id": "el-c4c", "content": "<code>image</code> — a figure with optional caption", "type": "text" }
          ],
          "list_type": "unordered",
          "type": "list"
        },
        {
          "_id": "el-c5",
          "content": "Add elements in <code>arc.collections.json</code> and they appear here — no page changes required.",
          "type": "blockquote"
        }
      ],
