---
import { getLiveCollection } from "astro:content";
import { type ArcStoryShape, formatDisplayDate } from "../lib/arc-story";

const result = await getLiveCollection("front", { context: Astro.locals.arc });
let stories: ArcStoryShape[] = [];
if (result.error) {
  Astro.response.status = 502;
} else {
  stories = result.entries.map((e) => e.data) as ArcStoryShape[];
}
const errored = !!result.error;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Arc Astro Default</title>
    <style>
      :root {
        color-scheme: light;
      }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        max-width: 80rem;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        color: #111;
        background: #fafafa;
      }
      h1 {
        font-size: 2rem;
        margin: 0 0 2rem;
        letter-spacing: -0.02em;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
        gap: 1.5rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      article {
        display: flex;
        flex-direction: column;
        border: 1px solid #e5e5e5;
        border-radius: 0.75rem;
        overflow: hidden;
        background: #fff;
        transition: box-shadow 0.15s ease;
      }
      article:hover {
        box-shadow: 0 6px 24px -8px rgba(0, 0, 0, 0.12);
      }
      .hero {
        display: block;
        aspect-ratio: 16 / 9;
        background: #f0f0f0;
        overflow: hidden;
      }
      .hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .body {
        padding: 1rem 1.25rem 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
      }
      .section {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #888;
        font-weight: 600;
      }
      h2 {
        font-size: 1.125rem;
        line-height: 1.3;
        margin: 0;
        font-weight: 600;
      }
      h2 a {
        color: #111;
        text-decoration: none;
      }
      h2 a:hover {
        text-decoration: underline;
      }
      .desc {
        font-size: 0.9375rem;
        color: #555;
        margin: 0;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      footer.byline {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.75rem 1.25rem 1rem;
        border-top: 1px solid #f0f0f0;
        font-size: 0.8125rem;
        color: #555;
      }
      .avatar {
        width: 1.75rem;
        height: 1.75rem;
        border-radius: 50%;
        object-fit: cover;
      }
      .author-meta {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
      }
      .author-name {
        font-weight: 500;
        color: #222;
      }
      .author-role {
        font-size: 0.75rem;
        color: #888;
      }
      .date {
        margin-left: auto;
        font-size: 0.75rem;
        color: #888;
      }
      .empty {
        color: #888;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <h1>Section front</h1>
    {errored ? (
      <p class="empty">Content is temporarily unavailable. Please try again shortly.</p>
    ) : stories.length === 0 ? (
      <p class="empty">No stories in this collection yet.</p>
    ) : (
      <ul class="grid">
        {stories.map((story) => {
          const url = story.canonical_url ?? "#";
          const img = story.promo_items?.basic;
          const headline = story.headlines?.basic ?? "(untitled)";
          const desc = story.description?.basic;
          const author = story.credits?.by?.[0];
          const section = story.taxonomy?.primary_section?.name;
          const date = formatDisplayDate(story.display_date);
          return (
            <li>
              <article>
                {img?.url && (
                  <a href={url} class="hero" aria-label={headline}>
                    <img
                      src={img.url}
                      alt={img.alt_text ?? ""}
                      width={img.width}
                      height={img.height}
                      loading="lazy"
                    />
                  </a>
                )}
                <div class="body">
                  {section && <span class="section">{section}</span>}
                  <h2><a href={url}>{headline}</a></h2>
                  {desc && <p class="desc">{desc}</p>}
                </div>
                {(author?.name || date) && (
                  <footer class="byline">
                    {author?.image?.url && (
                      <img class="avatar" src={author.image.url} alt="" loading="lazy" />
                    )}
                    {author?.name && (
                      <div class="author-meta">
                        <span class="author-name">{author.name}</span>
                        {author.additional_properties?.original?.role && (
                          <span class="author-role">{author.additional_properties.original.role}</span>
                        )}
                      </div>
                    )}
                    {date && <span class="date">{date}</span>}
                  </footer>
                )}
              </article>
            </li>
          );
        })}
      </ul>
    )}
  </body>
</html>
