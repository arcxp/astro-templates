---
import { getLiveCollection } from "astro:content";
import { type ArcStoryShape } from "../lib/arc-story";
import BaseLayout from "../layouts/BaseLayout.astro";
import StoryCard from "../components/StoryCard.astro";

const result = await getLiveCollection("blog", { context: Astro.locals.arc });
let stories: ArcStoryShape[] = [];
if (result.error) {
  Astro.response.status = 502;
} else {
  stories = result.entries.map((e) => e.data) as ArcStoryShape[];
}
const errored = !!result.error;
---
<BaseLayout title="Blog — Arc Astro">
  <h1>Blog</h1>
  {errored ? (
    <p class="empty">Content is temporarily unavailable. Please try again shortly.</p>
  ) : stories.length === 0 ? (
    <p class="empty">No posts in this collection yet.</p>
  ) : (
    <ul class="grid">
      {stories.map((story) => (
        <li><StoryCard story={story} /></li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
