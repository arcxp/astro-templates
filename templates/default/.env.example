# Fixture mode is on by default so the first run works offline with no token.
# Set to false (or remove) and provide ARC_API_TOKEN to fetch live content.
ARC_USE_FIXTURES=true
LOG_LEVEL=debug

# Pin Astro's server-island encryption key so `arc build` is deterministic.
# Without it Astro regenerates the key every build, so the Worker bundle (and
# the deploy release id) changes each time and every deploy re-uploads an
# otherwise-unchanged build. Generate one with `pnpm exec astro create-key`
# and paste it here. In production this is a managed per-site secret injected
# by the Control Plane — don't commit a real value.
ASTRO_KEY=
